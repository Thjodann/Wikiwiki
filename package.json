{
  "name": "@thjodann/wk",
  "version": "1.0.2",
  "description": "Wikiwiki is an agent-native living documentation system for code repos.",
  "license": "MIT",
  "type": "commonjs",
  "homepage": "https://github.com/Thjodann/Wikiwiki#readme",
  "bugs": {
    "url": "https://github.com/Thjodann/Wikiwiki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thjodann/Wikiwiki.git"
  },
  "keywords": [
    "agents",
    "documentation",
    "knowledge-base",
    "cli",
    "wiki"
  ],
  "files": [
    "dist",
    "README.md",
    "docs",
    "LICENSE",
    "skills/wk"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "wk": "dist/index.js",
    "wikiwiki": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/*.test.js",
    "check": "npm run build && node dist/index.js validate --json",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "author": ""
}
